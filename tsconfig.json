{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM"],
		"jsx": "react-jsx",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"outDir": "dist",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src", "tests", "vite.config.ts"],
	"exclude": ["node_modules", "dist"]
}
