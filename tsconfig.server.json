{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"outDir": "dist/server",
		"rootDir": "src"
	},
	"include": ["src/server", "src/shared"],
	"exclude": ["node_modules", "dist"]
}
